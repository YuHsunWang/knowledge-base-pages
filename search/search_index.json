{"config":{"lang":["en","ja"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Shane's Knowledge Base","text":"<p>\u9019\u662f\u5f9e Obsidian Vault \u6574\u7406\u5f8c\u767c\u5e03\u7684\u516c\u958b\u77e5\u8b58\u7db2\u7ad9\u3002</p>"},{"location":"#_1","title":"\u5b9a\u4f4d","text":"<ul> <li>Obsidian Vault \u662f\u552f\u4e00\u77e5\u8b58\u4f86\u6e90\uff08Single Source of Truth\uff09\u3002</li> <li>Git / GitHub \u7528\u65bc\u7248\u672c\u63a7\u5236\u3001\u5099\u4efd\u8207\u5c08\u6848\u7ba1\u7406\u3002</li> <li>MkDocs \u53ea\u767c\u5e03\u5df2\u6574\u7406\u5b8c\u6210\u3001\u53ef\u516c\u958b\u7684\u5167\u5bb9\u3002</li> </ul>"},{"location":"#_2","title":"\u767c\u5e03\u539f\u5247","text":"<p>\u53ea\u6709\u7b26\u5408\u4ee5\u4e0b\u689d\u4ef6\u7684\u5167\u5bb9\u624d\u653e\u5165 <code>docs/</code>\uff1a</p> <ul> <li>\u5df2\u6574\u7406\u5b8c\u6210</li> <li>\u6709\u6458\u8981</li> <li>\u6709\u6848\u4f8b\u6216\u5be6\u4f5c\u7bc4\u4f8b</li> <li>\u6709\u81ea\u5df1\u7684\u7406\u89e3</li> <li>\u975e\u8349\u7a3f\u3001\u975e\u79c1\u4eba\u5167\u5bb9</li> </ul>"},{"location":"#_3","title":"\u4e3b\u8981\u5206\u985e","text":"<ul> <li>AI / AI Agent</li> <li>SQL</li> <li>Python</li> <li>Statistics</li> <li>Trading / Quant Research</li> <li>Data Science</li> <li>Machine Learning</li> <li>Projects</li> <li>Career</li> </ul> <p>\u521d\u59cb\u5316\u65e5\u671f\uff1a2026-05-26</p>"},{"location":"ai/","title":"AI / AI Agent","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 AI / AI Agent \u7b46\u8a18\u3002</p> <ul> <li>Andrej Karpathy \u7684 CLAUDE.md\uff1a\u77e5\u8b58\u5eab\u7dad\u904b\u539f\u5247\uff08\u6574\u7406\u7248\uff09</li> <li>\u7528 CLAUDE.md \u628a AI \u8b8a\u6210\u4f60\u7684 Obsidian \u77e5\u8b58\u5eab\u7dad\u8b77\u8005</li> </ul>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/","title":"\u5f9e Andrej Karpathy \u7684 CLAUDE.md \u5b78\u5230\u7684\u77e5\u8b58\u5eab\u7dad\u904b\u6cd5","text":"<p>\u5982\u679c\u4f60\u628a\u500b\u4eba\u77e5\u8b58\u5eab\u7576\u6210\u9577\u671f\u8cc7\u7522\uff0c\u800c\u4e0d\u662f\u4e00\u6b21\u6027\u7684\u7b46\u8a18\u8f38\u51fa\uff0c\u90a3\u9ebc\u7dad\u904b\u65b9\u5f0f\u5c31\u6703\u5b8c\u5168\u4e0d\u540c\u3002\u9019\u7bc7\u6587\u7ae0\u6574\u7406\u81ea Andrej Karpathy \u793e\u7fa4\u7248\u672c\u7684 CLAUDE.md\uff0c\u91cd\u9ede\u4e0d\u662f\u300c\u600e\u9ebc\u5beb\u4e00\u7bc7\u7b46\u8a18\u300d\uff0c\u800c\u662f\u300c\u600e\u9ebc\u8b93\u77e5\u8b58\u5eab\u8d8a\u7528\u8d8a\u6709\u50f9\u503c\u300d\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_1","title":"\u70ba\u4ec0\u9ebc\u9019\u4efd\u65b9\u6cd5\u503c\u5f97\u53c3\u8003","text":"<p>\u591a\u6578\u77e5\u8b58\u5eab\u5931\u6548\uff0c\u4e0d\u662f\u56e0\u70ba\u5167\u5bb9\u592a\u5c11\uff0c\u800c\u662f\u56e0\u70ba\u7f3a\u4e4f\u7dad\u904b\u7d00\u5f8b\uff1a</p> <ul> <li>\u65b0\u8cc7\u6599\u9032\u4f86\u6642\u6c92\u6709\u56fa\u5b9a\u5438\u6536\u6d41\u7a0b</li> <li>\u820a\u5167\u5bb9\u904e\u671f\u4e86\u6c92\u4eba\u767c\u73fe</li> <li>\u76f8\u540c\u4e3b\u984c\u6563\u843d\u591a\u8655\uff0c\u96e3\u4ee5\u56de\u6536\u91cd\u7528</li> </ul> <p>Karpathy \u9019\u5957\u65b9\u6cd5\u7684\u6838\u5fc3\u5728\u65bc\uff1a\u628a\u77e5\u8b58\u5eab\u7576\u6210\u53ef\u6301\u7e8c\u7dad\u8b77\u7684\u7cfb\u7d71\uff0c\u4e26\u8b93 AI \u4ee3\u7406\u8ca0\u8cac\u91cd\u8907\u4e14\u53ef\u898f\u7bc4\u5316\u7684\u5de5\u4f5c\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_2","title":"\u4e00\u3001\u5148\u628a\u9801\u9762\u89d2\u8272\u5206\u6e05\u695a","text":"<p>\u77e5\u8b58\u9801\u5982\u679c\u6c92\u6709\u578b\u5225\uff0c\u5f8c\u7e8c\u67e5\u8a62\u8207\u7dad\u8b77\u5c31\u6703\u6df7\u4e82\u3002\u5efa\u8b70\u6700\u5c11\u5206\u6210\u56db\u985e\uff1a</p> <ul> <li>Concept\uff1a\u62bd\u8c61\u6982\u5ff5\u3001\u65b9\u6cd5\u3001\u6846\u67b6</li> <li>Entity\uff1a\u4eba\u3001\u516c\u53f8\u3001\u5de5\u5177\u3001\u8cc7\u6599\u96c6</li> <li>Synthesis\uff1a\u8de8\u4f86\u6e90\u6574\u5408\u5f8c\u7684\u6d1e\u898b</li> <li>Timeline\uff1a\u4e8b\u4ef6\u6642\u5e8f\u8207\u6f14\u9032</li> </ul> <p>\u9019\u500b\u5206\u985e\u7684\u50f9\u503c\uff0c\u4e0d\u5728\u65bc\u6f02\u4eae\uff0c\u800c\u5728\u65bc\u4f60\u5f8c\u7e8c\u80fd\u5feb\u901f\u56de\u7b54\u4e09\u4ef6\u4e8b\uff1a</p> <ol> <li>\u9019\u662f\u5b9a\u7fa9\u578b\u5167\u5bb9\u9084\u662f\u89c0\u5bdf\u578b\u5167\u5bb9\uff1f</li> <li>\u9019\u9801\u61c9\u8a72\u8ddf\u54ea\u4e9b\u9801\u5efa\u7acb\u9023\u7d50\uff1f</li> <li>\u9019\u9801\u4e0b\u4e00\u6b21\u8a72\u600e\u9ebc\u88ab\u66f4\u65b0\uff1f</li> </ol>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#ingest","title":"\u4e8c\u3001Ingest\uff1a\u65b0\u8cc7\u6599\u9032\u4f86\u6642\u7684\u6a19\u6e96\u4e94\u6b65\u9a5f","text":"<p>\u7576\u4f60\u8981\u300c\u6d88\u5316\u4e00\u7bc7\u6587\u7ae0\u3001\u4e00\u4efd\u6587\u4ef6\u3001\u4e00\u6bb5\u6703\u8b70\u7d00\u9304\u300d\u6642\uff0c\u6d41\u7a0b\u53ef\u4ee5\u56fa\u5b9a\u6210\u4e94\u6b65\uff1a</p> <ol> <li>\u8b80\u4f86\u6e90</li> <li>\u62bd\u53d6\u5be6\u9ad4\u3001\u6982\u5ff5\u3001\u4e3b\u5f35\u8207\u6578\u64da</li> <li>\u65e2\u6709\u9801\u9762\u5c31\u66f4\u65b0\uff0c\u6c92\u6709\u5c31\u65b0\u5efa</li> <li>\u5728\u9801\u5c3e\u6a19\u8a3b\u4f86\u6e90\u8207\u6642\u9593</li> <li>\u66f4\u65b0\u7d22\u5f15\u9801\uff08\u907f\u514d\u65b0\u9801\u6210\u70ba\u5b64\u5152\uff09</li> </ol> <p>\u91cd\u9ede\u662f\uff1a\u77e5\u8b58\u5eab\u662f\u7d2f\u7a4d\u7cfb\u7d71\uff0c\u4e0d\u662f\u8986\u84cb\u7cfb\u7d71\u3002\u820a\u8cc7\u8a0a\u4e0d\u61c9\u96a8\u610f\u522a\u9664\uff0c\u800c\u662f\u6a19\u8a18\u5df2\u66f4\u65b0\u3001\u5f85\u9a57\u8b49\uff0c\u4fdd\u7559\u53ef\u8ffd\u6eaf\u8108\u7d61\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#query","title":"\u4e09\u3001Query\uff1a\u56de\u7b54\u554f\u984c\u6642\uff0c\u4e0d\u8981\u76f4\u63a5\u6191\u5370\u8c61\u751f\u6210","text":"<p>\u771f\u6b63\u53ef\u9760\u7684\u77e5\u8b58\u5eab\u56de\u7b54\u6d41\u7a0b\uff0c\u61c9\u8a72\u662f\uff1a</p> <ol> <li>\u5148\u770b\u7d22\u5f15\uff0c\u5b9a\u4f4d\u76f8\u95dc\u9801\u9762</li> <li>\u8b80\u9801\u9762\u5f8c\u518d\u7d44\u5408\u7b54\u6848</li> <li>\u5982\u679c\u56de\u7b54\u904e\u7a0b\u7522\u751f\u65b0\u7d50\u8ad6\uff0c\u56de\u5beb\u6210 synthesis</li> </ol> <p>\u9019\u6703\u628a\u300c\u4e00\u6b21\u6027\u56de\u7b54\u300d\u8b8a\u6210\u300c\u53ef\u56de\u6536\u8cc7\u7522\u300d\u3002\u4e0b\u4e00\u6b21\u540c\u4e3b\u984c\u63d0\u554f\uff0c\u4e0d\u7528\u5f9e\u96f6\u958b\u59cb\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#lint","title":"\u56db\u3001Lint\uff1a\u5b9a\u671f\u5065\u5eb7\u6aa2\u67e5\uff0c\u9632\u6b62\u77e5\u8b58\u8150\u6557","text":"<p>\u77e5\u8b58\u5eab\u6700\u6015\u7684\u662f\u6c89\u9ed8\u5730\u904e\u671f\u3002\u5efa\u8b70\u56fa\u5b9a\u6aa2\u67e5\u56db\u4ef6\u4e8b\uff1a</p> <ul> <li>\u4e92\u76f8\u77db\u76fe\u7684\u6558\u8ff0</li> <li>\u6709\u660e\u78ba\u6642\u6548\u4f46\u5df2\u904e\u671f\u7684\u5167\u5bb9</li> <li>\u6c92\u6709\u4efb\u4f55\u5165\u93c8\u7684\u5b64\u5152\u9801</li> <li>\u9577\u671f\u53cd\u8986\u51fa\u73fe\u3001\u537b\u6c92\u6709\u88ab\u6574\u7406\u6210\u4e3b\u984c\u9801\u7684\u7f3a\u53e3</li> </ul> <p>Lint \u7684\u8f38\u51fa\u8981\u662f\u300c\u554f\u984c + \u4fee\u6b63\u5efa\u8b70\u300d\uff0c\u800c\u4e0d\u662f\u53ea\u6709\u554f\u984c\u6e05\u55ae\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_3","title":"\u4e94\u3001\u516c\u958b\u767c\u5e03\u524d\uff0c\u5148\u904e\u6700\u5c0f\u9580\u6abb","text":"<p>\u4e0d\u662f\u6240\u6709\u6574\u7406\u597d\u7684\u5167\u5bb9\u90fd\u9069\u5408\u516c\u958b\u3002\u81f3\u5c11\u8981\u6eff\u8db3\uff1a</p> <ul> <li>\u5167\u5bb9\u5df2\u5b8c\u6210\u6574\u7406\uff08\u975e\u8349\u7a3f\uff09</li> <li>\u6709\u6458\u8981\u8207\u53ef\u91cd\u7528\u4f8b\u5b50</li> <li>\u6709\u4f5c\u8005\u81ea\u5df1\u7684\u7406\u89e3\u8207\u9650\u5236\u8aaa\u660e</li> <li>\u4e0d\u542b\u500b\u8cc7\u3001\u6191\u8b49\u3001\u654f\u611f\u8b58\u5225\u8cc7\u8a0a</li> </ul> <p>\u628a\u9019\u500b\u9580\u6abb\u56fa\u5b9a\u4e0b\u4f86\uff0c\u4f60\u7684\u516c\u958b\u5167\u5bb9\u54c1\u8cea\u6703\u66f4\u7a69\uff0c\u4e5f\u66f4\u4e0d\u5bb9\u6613\u8aa4\u6d29\u6f0f\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_4","title":"\u516d\u3001\u5be6\u52d9\u4e0a\u6700\u5bb9\u6613\u5ffd\u7565\u7684\u5169\u4ef6\u4e8b","text":""},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#1","title":"1) \u4f86\u6e90\u6a19\u8a3b","text":"<p>\u6c92\u6709\u4f86\u6e90\uff0c\u5167\u5bb9\u53ef\u4fe1\u5ea6\u6703\u5feb\u901f\u8870\u9000\uff1b\u6709\u4f86\u6e90\uff0c\u624d\u6709\u56de\u982d\u9a57\u8b49\u7684\u80fd\u529b\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#2","title":"2) \u7d22\u5f15\u66f4\u65b0","text":"<p>\u5f88\u591a\u77e5\u8b58\u5eab\u4e0d\u662f\u7f3a\u5167\u5bb9\uff0c\u800c\u662f\u300c\u627e\u4e0d\u5230\u5167\u5bb9\u300d\u3002\u7d22\u5f15\u662f\u6aa2\u7d22\u6548\u7387\u7684\u5730\u57fa\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_5","title":"\u7d50\u8a9e","text":"<p>Karpathy \u9019\u4efd CLAUDE.md \u7684\u50f9\u503c\uff0c\u4e0d\u5728\u6280\u5de7\u6e05\u55ae\uff0c\u800c\u5728\u4e00\u500b\u89c0\u5ff5\uff1a</p> <p>\u628a\u77e5\u8b58\u5eab\u7576\u6210\u9577\u671f\u7dad\u8b77\u7684\u7cfb\u7d71\u3002</p> <p>\u7576\u4f60\u6709 ingest\u3001query\u3001lint \u4e09\u500b\u56fa\u5b9a\u8ff4\u8def\uff0c\u77e5\u8b58\u4e0d\u53ea\u6703\u589e\u52a0\uff0c\u9084\u6703\u9010\u6b65\u8b8a\u5f97\u66f4\u53ef\u7528\u3001\u66f4\u53ef\u9a57\u8b49\u3001\u66f4\u53ef\u91cd\u7528\u3002</p>"},{"location":"ai/claude-md-knowledge-base-maintenance-principles/#_6","title":"\u8cc7\u6599\u4f86\u6e90","text":"<ul> <li>\u539f\u59cb\u6587\u4ef6\uff1ahttps://github.com/multica-ai/andrej-karpathy-skills/blob/main/CLAUDE.md</li> <li>\u672c\u6587\u70ba\u4e2d\u6587\u91cd\u8ff0\u8207\u5be6\u52d9\u5316\u6574\u7406\uff0c\u4fdd\u7559\u65b9\u6cd5\u8ad6\uff0c\u975e\u9010\u5b57\u7ffb\u8b6f\u3002</li> </ul>"},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/","title":"\u7528 CLAUDE.md \u628a AI \u8b8a\u6210\u4f60\u7684 Obsidian \u77e5\u8b58\u5eab\u7dad\u8b77\u8005","text":"","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#_1","title":"\u6458\u8981","text":"<p>\u9019\u7bc7\u7b46\u8a18\u6574\u7406\u4e86\u6211\u76ee\u524d\u5728 Obsidian vault \u88e1\u4f7f\u7528\u7684 <code>CLAUDE.md</code>\u2014\u2014\u4e00\u4efd\u7d66 Claude \u770b\u7684\u64cd\u4f5c\u624b\u518a\uff0c\u8b93 AI \u5f9e\u4e00\u500b\u9010\u8f2a\u804a\u5929\u7684\u5de5\u5177\uff0c\u8b8a\u6210\u80fd\u5920\u6301\u7e8c\u7dad\u8b77\u3001\u67e5\u8a62\u3001\u5065\u5eb7\u6aa2\u67e5\u6211\u500b\u4eba\u77e5\u8b58\u5eab\u7684\u300c\u552f\u4e00\u7dad\u8b77\u8005\u300d\u3002</p> <p>\u6838\u5fc3\u6982\u5ff5\u4f86\u81ea Andrej Karpathy \u5c0d LLM Wiki \u7684\u8a2d\u8a08\u7406\u5ff5\uff1aAI \u4e0d\u53ea\u662f\u56de\u7b54\u554f\u984c\u7684\u5de5\u5177\uff0c\u800c\u662f\u77e5\u8b58\u5eab\u7684\u4e3b\u52d5\u6574\u7406\u8005\u3002\u672c\u6587\u63cf\u8ff0\u7684\u662f\u6211\u7684 vault-specific \u7248\u672c\uff0c\u4e0d\u662f Karpathy \u539f\u59cb\u8a2d\u8a08\uff0c\u4e5f\u4e0d\u662f coding guideline\u2014\u2014\u800c\u662f\u4e00\u500b\u91dd\u5c0d\u77e5\u8b58\u6574\u7406\u8207\u767c\u5e03\u5de5\u4f5c\u6d41\u7684\u64cd\u4f5c\u898f\u5247\u96c6\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#claudemd","title":"\u9019\u4efd CLAUDE.md \u89e3\u6c7a\u4ec0\u9ebc\u554f\u984c","text":"<p>\u4e00\u822c\u4eba\u7528 AI \u7684\u6a21\u5f0f\u662f\uff1a\u554f\u554f\u984c\u2192\u5f97\u5230\u7b54\u6848\u2192\u7d50\u675f\u3002\u6bcf\u6b21\u5c0d\u8a71\u90fd\u662f\u5b64\u7acb\u7684\uff0cAI \u6c92\u6709\u8a18\u61b6\uff0c\u77e5\u8b58\u4e5f\u4e0d\u6703\u7d2f\u7a4d\u3002</p> <p>\u9019\u500b\u554f\u984c\u5728\u500b\u4eba\u77e5\u8b58\u7ba1\u7406\uff08PKM\uff09\u5834\u666f\u88e1\u7279\u5225\u660e\u986f\uff1a\u4f60\u628a\u4e00\u7bc7\u8ad6\u6587\u4e1f\u7d66 Claude\uff0c\u5b83\u7d66\u4f60\u4e00\u500b\u6458\u8981\uff0c\u4f46\u9019\u500b\u6458\u8981\u4e0d\u6703\u81ea\u52d5\u548c\u4f60\u4e4b\u524d\u6574\u7406\u7684\u76f8\u95dc\u6982\u5ff5\u9023\u7d50\uff0c\u4e5f\u4e0d\u6703\u88ab\u5b58\u9032\u4f60\u7684\u7b46\u8a18\u7cfb\u7d71\u2014\u2014\u9664\u975e\u4f60\u81ea\u5df1\u52d5\u624b\u3002</p> <p><code>CLAUDE.md</code> \u8981\u89e3\u6c7a\u7684\u5c31\u662f\u9019\u500b\u554f\u984c\u3002\u5b83\u505a\u4e86\u4e09\u4ef6\u4e8b\uff1a</p> <ul> <li>\u5b9a\u7fa9 AI \u7684\u89d2\u8272\u8207\u908a\u754c\uff1a\u660e\u78ba\u544a\u8a34 Claude\u300c\u4f60\u662f\u9019\u500b wiki \u7684\u552f\u4e00\u7dad\u8b77\u8005\u300d\uff0c\u800c\u4e0d\u662f\u4e00\u500b\u6cdb\u7528\u554f\u7b54\u6a5f\u5668\u3002</li> <li>\u5efa\u7acb\u64cd\u4f5c\u5354\u8b70\uff1aIngest \u600e\u9ebc\u505a\u3001Query \u600e\u9ebc\u56de\u7b54\u3001Lint \u8981\u6aa2\u67e5\u4ec0\u9ebc\uff0c\u90fd\u6709\u660e\u78ba\u6b65\u9a5f\u3002</li> <li>\u8a2d\u5b9a\u8cc7\u6599\u593e\u6b0a\u9650\uff1a\u54ea\u4e9b\u8cc7\u6599\u593e\u53ef\u4ee5\u52d5\u3001\u54ea\u4e9b\u7d55\u5c0d\u4e0d\u80fd\u78b0\uff0c\u7528\u7d50\u69cb\u6027\u898f\u5247\u9632\u6b62 AI \u51fa\u8ecc\u3002</li> </ul>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#ai","title":"\u6838\u5fc3\u8a2d\u8a08\uff1a\u628a AI \u5f9e\u804a\u5929\u5de5\u5177\u8b8a\u6210\u77e5\u8b58\u5eab\u7dad\u8b77\u8005","text":"<p>\u9019\u500b\u8a2d\u8a08\u7684\u95dc\u9375\u8f49\u63db\u5728\u65bc\uff1a\u628a AI \u7684\u884c\u70ba\u5f9e\u300c\u56de\u7b54\u300d\u8f49\u63db\u70ba\u300c\u7dad\u8b77\u300d\u3002</p> <p>\u50b3\u7d71\u7528\u6cd5\u662f\uff1a\u4f60\u554f\uff0cAI \u7b54\u3002\u77e5\u8b58\u505c\u5728\u5c0d\u8a71\u88e1\u3002</p> <p>LLM Wiki \u7684\u7528\u6cd5\u662f\uff1a\u4f60\u9935\u8cc7\u6599\uff0cAI \u6574\u7406\u9032 wiki\uff1b\u4f60\u554f\u554f\u984c\uff0cAI \u5f9e wiki \u5408\u6210\u7b54\u6848\uff1b\u4f60\u5b9a\u671f\u8b93 AI \u505a\u5065\u5eb7\u6aa2\u67e5\uff0c\u78ba\u4fdd\u77e5\u8b58\u5eab\u7684\u4e00\u81f4\u6027\u3002</p> <p>\u9019\u500b\u8f49\u63db\u9700\u8981\u5e7e\u500b\u524d\u63d0\uff1a</p> <ul> <li>AI \u6bcf\u6b21\u9032\u5165\u5c0d\u8a71\u6642\u90fd\u80fd\u8b80\u5230\u9019\u4efd\u64cd\u4f5c\u624b\u518a\uff08<code>CLAUDE.md</code>\uff09\uff0c\u77e5\u9053\u81ea\u5df1\u5728\u54ea\u500b\u8108\u7d61\u4e0b\u5de5\u4f5c\u3002</li> <li>\u77e5\u8b58\u5eab\u6709\u56fa\u5b9a\u7684\u8cc7\u6599\u593e\u7d50\u69cb\u8207\u9801\u9762\u683c\u5f0f\uff0c\u8b93 AI \u77e5\u9053\u53bb\u54ea\u88e1\u627e\u3001\u600e\u9ebc\u5beb\u3002</li> <li>\u6709\u660e\u78ba\u7684\u300c\u9ec3\u91d1\u539f\u5247\u300d\uff1aWiki \u662f\u7d2f\u7a4d\u7684\uff0c\u53ea\u589e\u52a0\u8207\u4fee\u6b63\uff0c\u7d55\u4e0d\u522a\u9664\u6709\u4f86\u6e90\u6a19\u8a18\u7684\u8cc7\u8a0a\u3002</li> </ul> <p>\u9019\u500b\u8a2d\u8a08\u8b93\u6bcf\u6b21\u5c0d\u8a71\u90fd\u4e0d\u518d\u662f\u4e00\u6b21\u6027\u7684\u2014\u2014AI \u7684\u8f38\u51fa\u6703\u6c89\u6fb1\u9032\u77e5\u8b58\u5eab\uff0c\u4e0b\u6b21\u5c0d\u8a71\u53ef\u4ee5\u5728\u9019\u500b\u57fa\u790e\u4e0a\u7e7c\u7e8c\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#ingest-query-lint","title":"\u4e09\u500b\u57fa\u672c\u64cd\u4f5c\uff1aIngest / Query / Lint","text":"","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#ingest","title":"Ingest\uff1a\u6d88\u5316\u65b0\u8cc7\u6599","text":"<p>\u7576\u6211\u8aaa\u300c\u5e6b\u6211\u6d88\u5316\u9019\u7bc7\u300d\uff0c\u6216\u628a\u6587\u4ef6\u653e\u9032 <code>Sources/</code> \u8cc7\u6599\u593e\u6642\uff0cClaude \u6703\uff1a</p> <ol> <li>\u95b1\u8b80\u4f86\u6e90\u6587\u4ef6\uff0c\u63d0\u53d6\u5be6\u9ad4\u3001\u6982\u5ff5\u3001\u4e3b\u5f35\u3001\u6578\u64da\u3002</li> <li>\u9010\u4e00\u5224\u65b7\uff1aWiki \u88e1\u662f\u5426\u5df2\u6709\u5c0d\u61c9\u9801\u9762\uff1f</li> <li>\u6709 \u2192 \u66f4\u65b0\uff08\u52a0\u5165\u65b0\u8cc7\u8a0a\uff0c\u4fdd\u7559\u820a\u8cc7\u8a0a\uff09\u3002</li> <li>\u6c92\u6709 \u2192 \u65b0\u5efa\u9801\u9762\u3002</li> <li>\u5728\u6bcf\u500b\u66f4\u65b0\u6216\u65b0\u5efa\u7684\u9801\u9762\u5e95\u90e8\u6a19\u8a18\u4f86\u6e90\u8207\u65e5\u671f\u3002</li> <li>\u66f4\u65b0 <code>Wiki/_Index.md</code> \u7684\u9801\u9762\u6e05\u55ae\u3002</li> </ol> <p>\u9ec3\u91d1\u539f\u5247\u518d\u5f37\u8abf\u4e00\u6b21\uff1a\u77e5\u8b58\u53ea\u80fd\u7d2f\u7a4d\uff0c\u4e0d\u80fd\u88ab\u8986\u84cb\u522a\u9664\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#query","title":"Query\uff1a\u56de\u7b54\u554f\u984c","text":"<p>\u7576\u6211\u554f\u554f\u984c\u6642\uff0cClaude \u4e0d\u662f\u76f4\u63a5\u7528\u8a13\u7df4\u8cc7\u6599\u56de\u7b54\uff0c\u800c\u662f\uff1a</p> <ol> <li>\u5148\u8b80 <code>Wiki/_Index.md</code>\uff0c\u78ba\u8a8d\u77e5\u8b58\u5eab\u88e1\u6709\u54ea\u4e9b\u9801\u9762\u3002</li> <li>\u8b80\u53d6\u76f8\u95dc\u9801\u9762\u3002</li> <li>\u5f9e wiki \u5167\u5bb9\u5408\u6210\u7b54\u6848\u3002</li> <li>\u82e5\u5206\u6790\u904e\u7a0b\u4e2d\u7522\u751f\u65b0\u6d1e\u898b\uff0c\u4e3b\u52d5\u65b0\u5efa\u4e00\u500b <code>type: synthesis</code> \u7684\u7d9c\u5408\u5206\u6790\u9801\u9762\u3002</li> </ol> <p>\u9019\u6a23\u7684\u8a2d\u8a08\u8b93\u7b54\u6848\u6709\u51fa\u8655\uff0c\u4e5f\u8b93\u5206\u6790\u672c\u8eab\u6210\u70ba\u77e5\u8b58\u5eab\u7684\u4e00\u90e8\u5206\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#lint","title":"Lint\uff1a\u5065\u5eb7\u6aa2\u67e5","text":"<p>\u7576\u6211\u8aaa\u300c\u5e6b\u6211\u505a lint\u300d\uff0cClaude \u6703\u6383\u63cf\u6574\u500b Wiki\uff0c\u627e\u51fa\uff1a</p> <ul> <li>\u4e92\u76f8\u77db\u76fe\u7684\u4e3b\u5f35\u3002</li> <li>\u904e\u6642\u8cc7\u8a0a\uff08\u6709\u660e\u78ba\u65e5\u671f\u53ef\u5224\u65b7\u7684\uff09\u3002</li> <li>\u5b64\u5152\u9801\u9762\uff08\u6c92\u6709\u88ab\u5176\u4ed6\u9801\u9762\u9023\u7d50\u7684\uff09\u3002</li> <li>\u660e\u986f\u7684\u8cc7\u8a0a\u7f3a\u53e3\u3002</li> </ul> <p>\u6700\u5f8c\u7522\u51fa\u4e00\u4efd\u5831\u544a\uff0c\u9010\u689d\u5217\u51fa\u554f\u984c\u8207\u5efa\u8b70\u4fee\u6b63\u65b9\u5f0f\u3002</p> <p>\u9019\u500b\u64cd\u4f5c\u8b93\u77e5\u8b58\u5eab\u4e0d\u6703\u96a8\u8457\u6642\u9593\u7d2f\u7a4d\u8b8a\u6210\u4e00\u5806\u96dc\u4e82\u3001\u77db\u76fe\u7684\u788e\u7247\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#_2","title":"\u8cc7\u6599\u593e\u6b0a\u9650\u8207\u5b89\u5168\u908a\u754c","text":"<p>\u9019\u662f <code>CLAUDE.md</code> \u6700\u91cd\u8981\u7684\u300c\u7d50\u69cb\u6027\u4fdd\u8b77\u300d\u3002\u6211\u7684 vault \u6709\u5e7e\u500b\u8cc7\u6599\u593e\u6709\u660e\u78ba\u7684\u8b80\u5beb\u9650\u5236\uff1a</p> <ul> <li><code>Sources/</code>\uff1a\u539f\u59cb\u8cc7\u6599\uff0c\u53ea\u8b80\u3002Claude \u53ef\u4ee5\u8b80\u4f86\u6d88\u5316\uff0c\u4f46\u7d55\u5c0d\u4e0d\u80fd\u4fee\u6539\u3002</li> <li><code>Wiki/</code>\uff1aClaude \u7684\u4e3b\u6230\u5834\uff0c\u53ef\u4ee5\u5efa\u7acb\u8207\u66f4\u65b0\u9801\u9762\u3002</li> <li><code>Notes/</code>\uff1a\u4f7f\u7528\u8005\u79c1\u4eba\u7b46\u8a18\uff0cClaude \u4e0d\u80fd\u52d5\u3002</li> <li><code>docs/</code>\uff1aMkDocs \u516c\u958b\u7db2\u7ad9\u4f86\u6e90\uff0c\u53ea\u653e\u5df2\u6574\u7406\u5b8c\u6210\u4e14\u901a\u904e\u767c\u5e03\u689d\u4ef6\u7684\u5167\u5bb9\u3002</li> </ul> <p>\u9019\u4e9b\u9650\u5236\u4e0d\u662f\u4fe1\u4efb\u554f\u984c\uff0c\u800c\u662f\u8077\u8cac\u5206\u5de5\u3002<code>Sources/</code> \u4fdd\u7559\u539f\u59cb\u6027\uff0c<code>Notes/</code> \u4fdd\u7559\u79c1\u4eba\u7a7a\u9593\uff0c<code>Wiki/</code> \u624d\u662f AI \u7684\u5de5\u4f5c\u5340\u57df\u3002</p> <p>\u6b64\u5916\u6709\u5e7e\u689d\u7981\u6b62\u4e8b\u9805\uff1a - \u4e0d\u634f\u9020\u8cc7\u8a0a\u3002\u82e5\u4e0d\u78ba\u5b9a\uff0c\u5beb\u300c\u5f85\u78ba\u8a8d\u300d\u3002 - \u4e0d\u522a\u9664\u6709\u4f86\u6e90\u6a19\u8a18\u7684\u8cc7\u8a0a\uff0c\u53ea\u80fd\u6a19\u6ce8\u300c\u5df2\u66f4\u65b0\u300d\u6216\u300c\u5f85\u9a57\u8b49\u300d\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#obsidian-github-pages","title":"\u5f9e Obsidian \u5230 GitHub Pages \u7684\u767c\u5e03\u6d41\u7a0b","text":"<p>\u77e5\u8b58\u6574\u7406\u7684\u6700\u7d42\u76ee\u6a19\u662f\u8b93\u6709\u50f9\u503c\u7684\u5167\u5bb9\u53ef\u4ee5\u5c0d\u5916\u5206\u4eab\u3002\u6574\u500b\u6d41\u7a0b\u662f\uff1a</p> <pre><code>AI \u5354\u52a9\u6574\u7406\uff08Claude / Codex / GPT\uff09\n        \u2193\nObsidian Vault\uff08\u55ae\u4e00\u4e8b\u5be6\u4f86\u6e90\uff09\n        \u2193\nGitHub Private Repo\uff08\u7248\u672c\u63a7\u5236 / \u5099\u4efd\uff09\n        \u2193\nMkDocs\uff08\u516c\u958b\u77e5\u8b58\u7db2\u7ad9\u5efa\u7f6e\uff09\n        \u2193\nGitHub Pages\uff08\u5c0d\u5916\u767c\u5e03\uff09\n</code></pre>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#ai_1","title":"AI \u7522\u51fa\u7684\u5de5\u4f5c\u6d41","text":"<p>\u7576 AI \u56de\u7b54\u554f\u984c\u6216\u7522\u751f\u5206\u6790\u6642\uff1a</p> <ol> <li>\u5148\u56de\u7b54\u554f\u984c\u3002</li> <li>\u518d\u7522\u751f\u53ef\u4fdd\u5b58\u7684\u7248\u672c\u3002</li> <li>\u8f49\u63db\u6210 Obsidian Markdown \u683c\u5f0f\u3002</li> <li>\u65b0\u5167\u5bb9\u9810\u8a2d\u5148\u653e <code>Inbox/</code>\uff0c\u6574\u7406\u5b8c\u6210\u5f8c\u518d\u79fb\u81f3 <code>Knowledge/</code>\u3002</li> </ol> <p>\u9019\u500b\u300c\u5148\u8349\u7a3f\uff0c\u5f8c\u6574\u7406\u300d\u7684\u8a2d\u8a08\u907f\u514d\u4e86\u77e5\u8b58\u9084\u6c92\u6210\u719f\u5c31\u88ab\u932f\u8aa4\u5206\u985e\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#mkdocs","title":"\u767c\u5e03\u5230 MkDocs \u7684\u689d\u4ef6","text":"<p>\u4e0d\u662f\u6240\u6709\u7b46\u8a18\u90fd\u9069\u5408\u516c\u958b\u3002\u53ea\u6709\u7b26\u5408\u4ee5\u4e0b\u689d\u4ef6\u7684\u5167\u5bb9\u624d\u80fd\u79fb\u5165 <code>docs/</code>\uff1a</p> <ul> <li>\u5df2\u6574\u7406\u5b8c\u6210\uff0c\u4e0d\u662f\u8349\u7a3f\u3002</li> <li>\u6709\u6458\u8981\u3002</li> <li>\u6709\u6848\u4f8b\u6216\u5be6\u4f5c\u7bc4\u4f8b\u3002</li> <li>\u6709\u81ea\u5df1\u7684\u7406\u89e3\u8207\u8a6e\u91cb\uff08\u4e0d\u53ea\u662f\u8f49\u8ff0\uff09\u3002</li> <li>\u4e0d\u542b\u79c1\u4eba\u8cc7\u8a0a\u3001\u654f\u611f\u8cc7\u6599\u6216\u4e0d\u9069\u5408\u516c\u958b\u7684\u5167\u5bb9\u3002</li> </ul>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#git","title":"Git \u4f7f\u7528\u898f\u5247","text":"<ul> <li>GitHub private repo \u7528\u65bc\u7248\u672c\u63a7\u5236\u8207\u5099\u4efd\uff0c\u4e0d\u662f\u767c\u5e03\u7ba1\u9053\u3002</li> <li>\u4e0d\u628a\u5927\u578b\u539f\u59cb\u8cc7\u6599\u3001private data\u3001API keys\u3001token\u3001<code>.env</code>\u3001\u8cc7\u6599\u5eab\u6a94\u653e\u9032 Git\u3002</li> <li>GitHub Pages \u53ea\u767c\u5e03 MkDocs \u5f9e <code>docs/</code> \u7522\u751f\u7684\u5167\u5bb9\u3002</li> </ul>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#coding-guidelines-vault-rules","title":"\u70ba\u4ec0\u9ebc\u8981\u628a Coding Guidelines \u8207 Vault Rules \u5206\u958b","text":"<p>\u9019\u500b\u5206\u6d41\u8a2d\u8a08\u662f\u6574\u500b\u67b6\u69cb\u88e1\u6211\u6700\u60f3\u5f37\u8abf\u7684\u4e00\u500b\u6c7a\u7b56\u3002</p> <p>\u6211\u7684 vault \u6839\u76ee\u9304\u6709\u9019\u4efd <code>CLAUDE.md</code>\uff0c\u8ca0\u8cac\u77e5\u8b58\u5eab\u7684\u64cd\u4f5c\u898f\u5247\u3002\u4f46\u6211\u53e6\u5916\u9084\u6709 coding \u4efb\u52d9\u2014\u2014\u4fee\u6539 scripts\u3001\u6574\u7406\u5176\u4ed6 repo \u7684 <code>CLAUDE.md</code>\u3002\u9019\u5169\u4ef6\u4e8b\u7684\u898f\u5247\u662f\u4e0d\u540c\u7684\uff0c\u751a\u81f3\u6709\u6642\u5019\u662f\u4e92\u76f8\u77db\u76fe\u7684\u3002</p> <p>Coding guideline\uff08\u53c3\u8003\u81ea multica-ai \u6574\u7406\u7684 Andrej Karpathy coding \u6e96\u5247\uff09\u5f37\u8abf\u7684\u662f\uff1a\u6e2c\u8a66\u3001\u6700\u5c0f\u5316 diff\u3001\u4e0d\u8981\u91cd\u69cb\u6c92\u58de\u7684\u6771\u897f\u3002</p> <p>Vault rule \u5f37\u8abf\u7684\u662f\uff1a\u53ea\u589e\u52a0\u4e0d\u522a\u9664\u3001\u4fdd\u7559\u4f86\u6e90\u6a19\u8a18\u3001\u7528 Obsidian \u8a9e\u6cd5\u9023\u7d50\u3002</p> <p>\u5982\u679c\u628a\u9019\u5169\u5957\u898f\u5247\u6df7\u5728\u540c\u4e00\u500b\u6587\u4ef6\u88e1\uff0cAI \u5728\u505a\u77e5\u8b58\u6574\u7406\u6642\u53ef\u80fd\u6703\u5957\u7528 coding \u601d\u7dad\uff08\u4f8b\u5982\u300c\u522a\u9664\u91cd\u8907\u300d\uff09\uff0c\u53cd\u800c\u7834\u58de wiki \u7684\u7d2f\u7a4d\u6027\u3002</p> <p>\u89e3\u6cd5\u662f\u660e\u78ba\u5206\u6d41\uff1a - \u7dad\u8b77\u77e5\u8b58\u5eab\u3001\u6574\u7406\u7b46\u8a18\u3001\u767c\u5e03 docs \u6642\uff0c\u512a\u5148\u9075\u5b88 vault <code>CLAUDE.md</code>\u3002 - \u9032\u884c coding \u4efb\u52d9\u6642\uff0c\u5f15\u7528\u7368\u7acb\u4fdd\u5b58\u7684 coding guideline \u6587\u4ef6\u3002 - \u5169\u4efd\u6587\u4ef6\u4e92\u4e0d\u5e72\u64fe\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#_3","title":"\u53ef\u8907\u7528\u7684\u5be6\u4f5c\u539f\u5247","text":"<p>\u5982\u679c\u4f60\u60f3\u5728\u81ea\u5df1\u7684 vault \u8907\u88fd\u9019\u500b\u8a2d\u8a08\uff0c\u4ee5\u4e0b\u662f\u6700\u6838\u5fc3\u7684\u5e7e\u500b\u539f\u5247\uff1a</p> <p>\u660e\u78ba\u89d2\u8272\u5b9a\u7fa9\uff1a\u5728 <code>CLAUDE.md</code> \u7b2c\u4e00\u884c\u5c31\u8aaa\u6e05\u695a\u300c\u4f60\u662f\u9019\u500b wiki \u7684\u552f\u4e00\u7dad\u8b77\u8005\u300d\uff0c\u800c\u4e0d\u662f\u8b93 AI \u81ea\u5df1\u731c\u3002</p> <p>\u7528\u8cc7\u6599\u593e\u7d50\u69cb\u4ee3\u66ff\u898f\u5247\u63cf\u8ff0\uff1a\u8207\u5176\u5beb\u300c\u4e0d\u8981\u52d5\u79c1\u4eba\u7b46\u8a18\u300d\uff0c\u4e0d\u5982\u76f4\u63a5\u5b9a\u7fa9 <code>Notes/</code> \u662f\u7981\u6b62\u4fee\u6539\u5340\u3002\u7d50\u69cb\u6bd4\u6587\u5b57\u66f4\u96e3\u88ab\u8aa4\u89e3\u3002</p> <p>\u64cd\u4f5c\u6b65\u9a5f\u8981\u660e\u78ba\u5230\u53ef\u57f7\u884c\uff1a\u300c\u6574\u7406\u8cc7\u6599\u300d\u662f\u6c92\u7528\u7684\u6307\u4ee4\u3002\u300c\u8b80\u53d6\u4f86\u6e90 \u2192 \u63d0\u53d6\u5be6\u9ad4 \u2192 \u6bd4\u5c0d wiki \u2192 \u66f4\u65b0\u6216\u65b0\u5efa \u2192 \u6a19\u8a18\u4f86\u6e90 \u2192 \u66f4\u65b0 index\u300d\u624d\u662f\u53ef\u57f7\u884c\u7684\u6b65\u9a5f\u3002</p> <p>\u7d2f\u7a4d\u6027\u662f wiki \u7684\u6838\u5fc3\u4e0d\u8b8a\u91cf\uff1a\u9019\u4e00\u689d\u5fc5\u9808\u5beb\u9032\u7981\u6b62\u4e8b\u9805\uff0c\u4e0d\u80fd\u53ea\u662f\u539f\u5247\u3002AI \u5929\u751f\u6709\u300c\u6574\u5408\u8207\u522a\u9664\u91cd\u8907\u300d\u7684\u50be\u5411\uff0c\u5fc5\u9808\u660e\u78ba\u6291\u5236\u3002</p> <p>\u767c\u5e03\u689d\u4ef6\u8981\u5177\u9ad4\uff1a\u300c\u6574\u7406\u5b8c\u6210\u300d\u4e0d\u662f\u689d\u4ef6\uff0c\u300c\u6709\u6458\u8981 + \u6709\u6848\u4f8b + \u6709\u81ea\u5df1\u7684\u7406\u89e3 + \u975e\u8349\u7a3f\u300d\u624d\u662f\u689d\u4ef6\u3002\u6a21\u7cca\u7684\u689d\u4ef6\u7b49\u65bc\u6c92\u6709\u689d\u4ef6\u3002</p> <p>\u5206\u6d41\u7ba1\u7406\u4e0d\u540c\u8108\u7d61\u4e0b\u7684\u898f\u5247\uff1a\u5982\u679c\u4f60\u540c\u6642\u7528 AI \u505a\u77e5\u8b58\u6574\u7406\u548c coding\uff0c\u628a\u5169\u5957\u898f\u5247\u653e\u5728\u4e0d\u540c\u6587\u4ef6\uff0c\u5728\u4e0d\u540c\u8108\u7d61\u4e0b\u5f15\u7528\u4e0d\u540c\u6587\u4ef6\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"ai/claude-md-obsidian-llm-wiki-maintainer/#_4","title":"\u5ef6\u4f38\u95b1\u8b80","text":"<ul> <li>Andrej Karpathy \u95dc\u65bc LLM Wiki \u6982\u5ff5\u7684\u8a0e\u8ad6\uff08\u53ef\u641c\u5c0b\u5176 X / Twitter \u8cbc\u6587\u8207\u8a2a\u8ac7\uff09</li> <li>multica-ai \u6574\u7406\u7684 CLAUDE.md coding guideline\uff08GitHub\uff1a<code>multica-ai/andrej-karpathy-skills</code>\uff09</li> <li>MkDocs \u5b98\u65b9\u6587\u4ef6\uff08mkdocs.org\uff09\u2014\u2014\u7528\u65bc\u8a2d\u5b9a <code>docs/</code> \u5230 GitHub Pages \u7684\u767c\u5e03\u6d41\u7a0b</li> <li>Obsidian \u5b98\u65b9\u6587\u4ef6\u2014\u2014\u7279\u5225\u662f frontmatter \u8207\u5167\u90e8\u9023\u7d50\uff08<code>[[]]</code> \u8a9e\u6cd5\uff09\u7684\u8a2d\u8a08</li> </ul> <p>\u672c\u7b46\u8a18\u6574\u7406\u81ea\u6211\u76ee\u524d Obsidian vault \u6839\u76ee\u9304\u7684 <code>CLAUDE.md</code>\u3002\u6838\u5fc3\u6982\u5ff5\u53c3\u8003 Andrej Karpathy \u7684 LLM Wiki \u8a2d\u8a08\u7406\u5ff5\uff0c\u4ee5\u53ca multica-ai \u6574\u7406\u7684 CLAUDE.md coding guideline\uff0c\u4f46\u672c\u6587\u91cd\u9ede\u662f vault-specific \u7684\u77e5\u8b58\u5de5\u4f5c\u6d41\uff0c\u4e0d\u4ee3\u8868 Karpathy \u6216 multica-ai \u7684\u539f\u59cb\u8a2d\u8a08\u3002</p>","tags":["AI","Obsidian","LLM Wiki","Knowledge Management"]},{"location":"career/","title":"Career","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Career \u7b46\u8a18\u3002</p>"},{"location":"data-science/","title":"Data Science","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Data Science \u7b46\u8a18\u3002</p>"},{"location":"machine-learning/","title":"Machine Learning","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Machine Learning \u7b46\u8a18\u3002</p>"},{"location":"projects/","title":"Projects","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Projects \u7b46\u8a18\u3002</p>"},{"location":"projects/#_1","title":"\u5c08\u6848\u7b46\u8a18","text":"<ul> <li>TOEIC Master\uff1aAI \u9a45\u52d5\u7684\u96e2\u7dda\u591a\u76ca\u55ae\u5b57 PWA \u2014 React + Vite + IndexedDB + PWA + Gemini API \u7684\u591a\u76ca\u55ae\u5b57\u5b78\u7fd2 App\uff0c\u5305\u542b\u67b6\u69cb\u3001\u958b\u767c\u6d41\u7a0b\u3001\u6e2c\u8a66\u8207\u90e8\u7f72\u6d41\u7a0b\u3002</li> </ul>"},{"location":"projects/toeic-master/","title":"TOEIC Master\uff1aAI \u9a45\u52d5\u7684\u96e2\u7dda\u591a\u76ca\u55ae\u5b57 PWA","text":""},{"location":"projects/toeic-master/#_1","title":"\u4e00\u53e5\u8a71\u4ecb\u7d39","text":"<p>TOEIC Master \u662f\u4e00\u500b\u7528 React + Vite + IndexedDB + PWA + Gemini API \u505a\u6210\u7684\u591a\u76ca\u55ae\u5b57\u5b78\u7fd2 App\u3002\u5b83\u53ef\u4ee5\u5b89\u88dd\u5230\u624b\u6a5f\u4e3b\u756b\u9762\u3001\u96e2\u7dda\u4fdd\u5b58\u55ae\u5b57\u8207\u5b78\u7fd2\u72c0\u614b\uff0c\u4e26\u7528\u4e09\u5c64 fallback \u8a2d\u8a08\u8655\u7406\u82f1\u6587\u767c\u97f3\u3002</p> <p>\u5c08\u6848\u539f\u59cb\u78bc\uff1ahttps://github.com/YuHsunWang/toeic-master</p>"},{"location":"projects/toeic-master/#_2","title":"\u7522\u54c1\u529f\u80fd","text":"<ul> <li>AI \u751f\u6210 TOEIC \u6838\u5fc3\u55ae\u5b57\u3002</li> <li>\u5167\u5efa 8 \u500b\u7bc4\u4f8b\u55ae\u5b57\uff0c\u6c92\u6709 API key \u4e5f\u80fd\u6e2c\u3002</li> <li>\u55ae\u5b57\u8cc7\u6599\u5b58\u5728\u700f\u89bd\u5668 IndexedDB\uff0c\u4e0d\u9700\u8981\u5f8c\u7aef\u3002</li> <li>\u55ae\u5b57\u8207\u4f8b\u53e5\u53ef\u64ad\u653e\u767c\u97f3\u3002</li> <li>\u53ef\u9810\u8f09 Gemini TTS \u9ad8\u97f3\u8cea\u767c\u97f3\uff0c\u4e4b\u5f8c\u96e2\u7dda\u64ad\u653e\u3002</li> <li>\u6c92\u6709\u5feb\u53d6\u6216 API \u5931\u6557\u6642\uff0cfallback \u5230\u700f\u89bd\u5668\u5167\u5efa <code>SpeechSynthesis</code>\u3002</li> <li>\u652f\u63f4\u641c\u5c0b\u3001Reading / Listening / Both \u985e\u578b\u7be9\u9078\u3002</li> <li>\u652f\u63f4 Learning / Mastered \u72c0\u614b\u7be9\u9078\u3002</li> <li>\u53ef\u5b89\u88dd\u6210 PWA\uff0c\u624b\u6a5f\u4e0a\u50cf App \u4e00\u6a23\u4f7f\u7528\u3002</li> </ul>"},{"location":"projects/toeic-master/#_3","title":"\u6280\u8853\u67b6\u69cb","text":"<pre><code>React UI\n  \u2193\nDexie.js\n  \u2193\nIndexedDB\n  \u251c\u2500 vocab\uff1a\u55ae\u5b57\u8cc7\u6599\u3001\u985e\u578b\u3001\u638c\u63e1\u72c0\u614b\u3001\u6642\u9593\u6233\n  \u2514\u2500 ttsCache\uff1aTTS \u97f3\u6a94\u5feb\u53d6\n\nVite + vite-plugin-pwa\n  \u2193\nWorkbox service worker\n  \u2193\nApp shell \u96e2\u7dda\u5feb\u53d6\n\nGemini API\n  \u251c\u2500 \u751f\u6210 TOEIC \u55ae\u5b57 JSON\n  \u2514\u2500 \u7522\u751f\u9ad8\u97f3\u8cea TTS audio\n\nBrowser SpeechSynthesis\n  \u2193\n\u96e2\u7dda\u6216 API \u5931\u6557\u6642\u7684\u767c\u97f3 fallback\n</code></pre>"},{"location":"projects/toeic-master/#_4","title":"\u4e3b\u8981\u6a94\u6848\u8077\u8cac","text":"<ul> <li><code>src/App.jsx</code>\uff1a\u4e3b\u8981 UI \u8207\u4e92\u52d5\u6d41\u7a0b\uff0c\u5305\u542b AI \u751f\u6210\u3001\u9810\u8f09 TTS\u3001\u641c\u5c0b\u7be9\u9078\u3001\u638c\u63e1\u72c0\u614b\u5207\u63db\u3002</li> <li><code>src/db.js</code>\uff1aDexie / IndexedDB \u8cc7\u6599\u64cd\u4f5c\u5c64\u3002</li> <li><code>src/speechService.js</code>\uff1a\u8a9e\u97f3\u670d\u52d9\u8207\u4e09\u5c64 fallback\u3002</li> <li><code>src/seedData.js</code>\uff1a\u5167\u5efa 8 \u500b TOEIC \u7bc4\u4f8b\u55ae\u5b57\u3002</li> <li><code>vite.config.js</code>\uff1aReact plugin\u3001PWA manifest\u3001Workbox \u5feb\u53d6\u8a2d\u5b9a\u3002</li> <li><code>README.md</code>\uff1a\u5b89\u88dd\u3001API key\u3001PWA \u5b89\u88dd\u8207\u90e8\u7f72\u8aaa\u660e\u3002</li> <li><code>STACKBLITZ_GUIDE.md</code>\uff1a\u4e0d\u7528\u5b89\u88dd Node.js \u7684\u7dda\u4e0a\u6e2c\u8a66\u6d41\u7a0b\u3002</li> </ul>"},{"location":"projects/toeic-master/#_5","title":"\u8cc7\u6599\u6a21\u578b","text":""},{"location":"projects/toeic-master/#vocab","title":"vocab","text":"<pre><code>vocab: '++id, word, type, status, timestamp'\n</code></pre> <p>\u7528\u9014\uff1a\u4fdd\u5b58\u55ae\u5b57\u672c\u3002</p> <p>\u4ee3\u8868\u6b04\u4f4d\uff1a</p> <ul> <li><code>word</code>\uff1a\u82f1\u6587\u55ae\u5b57</li> <li><code>ipa</code>\uff1a\u97f3\u6a19</li> <li><code>pos</code>\uff1a\u8a5e\u6027</li> <li><code>zh</code>\uff1a\u4e2d\u6587\u610f\u601d</li> <li><code>en</code>\uff1a\u82f1\u6587\u89e3\u91cb</li> <li><code>sent</code>\uff1a\u4f8b\u53e5</li> <li><code>category</code>\uff1a\u5206\u985e</li> <li><code>type</code>\uff1a<code>Reading</code>\u3001<code>Listening</code>\u3001<code>Both</code></li> <li><code>status</code>\uff1a\u662f\u5426\u5df2\u638c\u63e1</li> <li><code>timestamp</code>\uff1a\u6392\u5e8f\u7528\u6642\u9593\u6233</li> </ul>"},{"location":"projects/toeic-master/#ttscache","title":"ttsCache","text":"<pre><code>ttsCache: 'key, timestamp'\n</code></pre> <p>\u7528\u9014\uff1a\u4fdd\u5b58 Gemini TTS \u56de\u50b3\u7684 PCM base64 \u97f3\u8a0a\u3002key \u683c\u5f0f\u662f\uff1a</p> <pre><code>{text}__{voice}\n</code></pre>"},{"location":"projects/toeic-master/#ai","title":"AI \u751f\u6210\u55ae\u5b57\u6d41\u7a0b","text":"<pre><code>\u4f7f\u7528\u8005\u9ede\u300c\u7372\u53d6 AI \u65b0\u55ae\u5b57\u300d\n  \u2193\n\u6aa2\u67e5\u662f\u5426\u5728\u7dda\u3001\u6709\u7121 Gemini API key\n  \u2193\n\u8b80\u53d6\u65e2\u6709\u55ae\u5b57\uff0c\u907f\u514d\u751f\u6210\u91cd\u8907\u5167\u5bb9\n  \u2193\nGemini \u56de\u50b3 JSON array\n  \u2193\n\u89e3\u6790\u6210 word / ipa / pos / zh / en / sent / category / type\n  \u2193\n\u5beb\u5165 IndexedDB\n  \u2193\nUI \u5373\u6642\u66f4\u65b0\n</code></pre> <p>\u9019\u88e1\u7684\u8a2d\u8a08\u91cd\u9ede\u662f\uff1aAI \u4e0d\u76f4\u63a5\u53d6\u4ee3\u8cc7\u6599\u5eab\uff0c\u800c\u662f\u4f5c\u70ba\u300c\u55ae\u5b57\u7522\u751f\u5668\u300d\uff1b\u771f\u6b63\u7684\u4f7f\u7528\u8005\u8cc7\u6599\u4ecd\u4fdd\u5b58\u5728 IndexedDB\u3002</p>"},{"location":"projects/toeic-master/#fallback","title":"\u767c\u97f3\u4e09\u5c64 fallback","text":"<p>\u9019\u662f\u5c08\u6848\u6700\u503c\u5f97\u5b78\u7fd2\u7684\u90e8\u5206\uff1a</p> <pre><code>1. \u5148\u67e5 IndexedDB TTS cache\n   \u6709\u5feb\u53d6 \u2192 \u76f4\u63a5\u64ad\u653e\uff0c\u5b8c\u5168\u96e2\u7dda\u53ef\u7528\n\n2. \u6c92\u5feb\u53d6\u4e14\u5728\u7dda\u3001\u6709 API key\n   \u547c\u53eb Gemini TTS \u2192 \u64ad\u653e \u2192 \u5beb\u56de IndexedDB cache\n\n3. Gemini \u5931\u6557\u6216\u96e2\u7dda\n   \u4f7f\u7528\u700f\u89bd\u5668\u5167\u5efa SpeechSynthesis\n</code></pre> <p>Gemini TTS \u56de\u50b3\u7684\u662f\u88f8 PCM\uff0c\u700f\u89bd\u5668\u4e0d\u80fd\u76f4\u63a5\u64ad\u653e\uff0c\u6240\u4ee5\u5c08\u6848\u6703\u5148\u628a PCM \u5305\u6210 WAV Blob\uff0c\u518d\u4ea4\u7d66 <code>Audio</code> \u64ad\u653e\u3002</p>"},{"location":"projects/toeic-master/#pwa","title":"PWA \u96e2\u7dda\u8a2d\u8a08","text":"<p>TOEIC Master \u7684\u96e2\u7dda\u80fd\u529b\u5206\u6210\u5169\u5c64\uff1a</p> <ol> <li>App shell \u96e2\u7dda\uff1aVite PWA / Workbox \u5feb\u53d6 HTML\u3001JS\u3001CSS\u3001\u5716\u7247\u8207 service worker\u3002</li> <li>\u4f7f\u7528\u8005\u8cc7\u6599\u96e2\u7dda\uff1aIndexedDB \u4fdd\u5b58\u55ae\u5b57\u3001\u638c\u63e1\u72c0\u614b\u8207 TTS \u5feb\u53d6\u3002</li> </ol> <p>\u56e0\u6b64\uff0c\u5373\u4f7f\u6c92\u6709\u7db2\u8def\uff0c\u53ea\u8981\u4e4b\u524d\u5df2\u7d93\u958b\u904e App\uff0c\u4ecd\u53ef\uff1a</p> <ul> <li>\u958b\u555f App</li> <li>\u770b\u65e2\u6709\u55ae\u5b57</li> <li>\u641c\u5c0b\u8207\u7be9\u9078</li> <li>\u6a19\u8a18\u5df2\u638c\u63e1</li> <li>\u64ad\u653e\u5df2\u5feb\u53d6\u7684\u9ad8\u97f3\u8cea TTS</li> <li>\u6216 fallback \u5230\u700f\u89bd\u5668\u8a9e\u97f3</li> </ul>"},{"location":"projects/toeic-master/#_6","title":"\u672c\u6a5f\u958b\u767c\u6d41\u7a0b","text":"<pre><code>git clone https://github.com/YuHsunWang/toeic-master.git\ncd toeic-master\nnpm install\ncp .env.example .env.local\n# \u7de8\u8f2f .env.local\uff1aVITE_GEMINI_API_KEY=\u4f60\u7684 Gemini API key\nnpm run dev\n</code></pre> <p>\u5e38\u7528\u6307\u4ee4\uff1a</p> <pre><code>npm run dev      # \u958b\u767c\u6a21\u5f0f\nnpm run build    # production build\nnpm run preview  # \u672c\u6a5f\u9810\u89bd production build\uff0c\u9069\u5408\u6e2c PWA\nnpm audit        # \u6aa2\u67e5 dependency vulnerability\n</code></pre>"},{"location":"projects/toeic-master/#_7","title":"\u6e2c\u8a66\u6d41\u7a0b","text":""},{"location":"projects/toeic-master/#_8","title":"\u57fa\u672c\u529f\u80fd\u6e2c\u8a66","text":"<ol> <li>\u555f\u52d5 App\uff0c\u78ba\u8a8d\u81ea\u52d5\u532f\u5165 8 \u500b\u7bc4\u4f8b\u55ae\u5b57\u3002</li> <li>\u9ede\u55ae\u5b57\u65c1\u5587\u53ed\uff0c\u78ba\u8a8d\u53ef\u64ad\u653e\u767c\u97f3\u3002</li> <li>\u9ede\u4f8b\u53e5\u64ad\u653e\uff0c\u78ba\u8a8d\u53e5\u5b50\u767c\u97f3\u53ef\u7528\u3002</li> <li>\u6a19\u8a18\u55ae\u5b57\u5df2\u638c\u63e1\uff0c\u78ba\u8a8d\u5361\u7247\u8b8a\u7070\u4e14 mastery rate \u66f4\u65b0\u3002</li> <li>\u641c\u5c0b <code>invoice</code> \u6216 <code>\u5354\u5546</code>\u3002</li> <li>\u5207\u63db Reading / Listening / Both \u7be9\u9078\u3002</li> <li>\u91cd\u65b0\u6574\u7406\u9801\u9762\uff0c\u78ba\u8a8d IndexedDB \u4fdd\u7559\u55ae\u5b57\u8207\u72c0\u614b\u3002</li> </ol>"},{"location":"projects/toeic-master/#pwa_1","title":"PWA \u96e2\u7dda\u6e2c\u8a66","text":"<pre><code>npm run build\nnpm run preview\n</code></pre> <p>\u7136\u5f8c\uff1a</p> <ol> <li>\u7528 Chrome \u958b\u555f preview URL\u3002</li> <li>DevTools \u2192 Application \u2192 Service Workers\uff0c\u78ba\u8a8d service worker \u8a3b\u518a\u3002</li> <li>DevTools \u2192 Network \u2192 Offline\u3002</li> <li>\u91cd\u65b0\u6574\u7406\u9801\u9762\uff0c\u78ba\u8a8d App \u4ecd\u80fd\u958b\u555f\u3002</li> <li>\u78ba\u8a8d\u65e2\u6709\u55ae\u5b57\u3001\u638c\u63e1\u72c0\u614b\u8207\u5df2\u5feb\u53d6\u767c\u97f3\u4ecd\u53ef\u7528\u3002</li> </ol>"},{"location":"projects/toeic-master/#stackblitz","title":"StackBlitz \u6e2c\u8a66","text":"<p>\u5c08\u6848\u9644\u6709 <code>STACKBLITZ_GUIDE.md</code>\uff0c\u53ef\u4ee5\u4e0d\u7528\u5b89\u88dd Node.js\uff0c\u76f4\u63a5\u4e0a\u50b3\u5230 StackBlitz \u6e2c\uff1a</p> <ul> <li>App \u662f\u5426\u555f\u52d5</li> <li>\u767c\u97f3\u662f\u5426\u53ef\u7528</li> <li>IndexedDB \u662f\u5426\u4fdd\u5b58\u72c0\u614b</li> <li>PWA \u662f\u5426\u53ef\u5b89\u88dd</li> <li>\u96e2\u7dda\u6a21\u5f0f\u662f\u5426\u6b63\u5e38</li> </ul>"},{"location":"projects/toeic-master/#_9","title":"\u90e8\u7f72\u6d41\u7a0b","text":"<p>TOEIC Master \u662f\u7d14\u524d\u7aef\u975c\u614b\u7db2\u7ad9\uff0c\u53ef\u90e8\u7f72\u5230\uff1a</p> <ul> <li>Vercel</li> <li>Netlify</li> <li>Cloudflare Pages</li> <li>GitHub Pages</li> <li>\u4efb\u610f\u975c\u614b\u6a94\u6848\u4e3b\u6a5f</li> </ul> <p>\u57fa\u672c\u90e8\u7f72\u6d41\u7a0b\uff1a</p> <pre><code>npm run build\n# \u767c\u5e03 dist/ \u76ee\u9304\n</code></pre> <p>\u6ce8\u610f\uff1aPWA \u9700\u8981 HTTPS \u6216 localhost\uff0c\u5426\u5247 service worker \u4e0d\u6703\u8a3b\u518a\u3002</p>"},{"location":"projects/toeic-master/#_10","title":"\u672c\u6b21\u6574\u7406\u6642\u7684\u9a57\u8b49\u7d50\u679c","text":"<p>\u6574\u7406\u9032\u77e5\u8b58\u5eab\u6642\uff0c\u5df2\u5728\u66ab\u5b58\u74b0\u5883\u57f7\u884c\uff1a</p> <pre><code>npm install\nnpm run build\nnpm audit --json\n</code></pre> <p>\u7d50\u679c\uff1a</p> <ul> <li>production build \u6210\u529f\u3002</li> <li>PWA \u7522\u7269\u6210\u529f\u7522\u751f\uff0c\u5305\u62ec <code>manifest.webmanifest</code>\u3001<code>sw.js</code>\u3001Workbox \u6a94\u6848\u3002</li> <li><code>npm audit</code> \u986f\u793a 2 \u500b moderate vulnerabilities\uff0c\u4e3b\u8981\u662f Vite / esbuild dev server \u76f8\u95dc\u554f\u984c\uff1b\u4fee\u5fa9\u5efa\u8b70\u6703\u5347\u5230 Vite 8\uff0c\u5c6c\u65bc major upgrade\uff0c\u9700\u53e6\u884c\u8a55\u4f30\u3002</li> </ul>"},{"location":"projects/toeic-master/#_11","title":"\u5f8c\u7e8c\u53ef\u6539\u9032\u65b9\u5411","text":"<ul> <li>\u88dc\u6b63\u5f0f PWA icon\uff1a<code>pwa-192x192.png</code>\u3001<code>pwa-512x512.png</code>\u3002</li> <li>\u52a0\u5165 ESLint / Prettier\u3002</li> <li>\u52a0\u5165 Playwright smoke test\u3002</li> <li>\u5c07 Gemini API key \u6539\u7531 serverless proxy \u7ba1\u7406\uff0c\u907f\u514d key \u66b4\u9732\u5728\u524d\u7aef bundle\u3002</li> <li>\u52a0\u5165\u55ae\u5b57\u532f\u5165 / \u532f\u51fa\u529f\u80fd\uff0c\u65b9\u4fbf\u5099\u4efd IndexedDB\u3002</li> <li>\u52a0\u5165 spaced repetition \u6b04\u4f4d\u8207\u8907\u7fd2\u6392\u7a0b\u3002</li> <li>\u82e5\u90e8\u7f72\u5230 GitHub Pages \u5b50\u8def\u5f91\uff0c\u88dc Vite <code>base</code> \u8207 PWA <code>start_url</code> \u8a2d\u5b9a\u3002</li> </ul>"},{"location":"python/","title":"Python","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Python \u7b46\u8a18\u3002</p>"},{"location":"sql/","title":"SQL","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 SQL \u7b46\u8a18\u3002</p>"},{"location":"statistics/","title":"Statistics","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Statistics \u7b46\u8a18\u3002</p>"},{"location":"trading/","title":"Trading / Quant Research","text":"<p>\u672c\u5340\u6536\u9304\u5df2\u6574\u7406\u5b8c\u6210\u3001\u9069\u5408\u516c\u958b\u767c\u5e03\u7684 Trading / Quant Research \u7b46\u8a18\u3002</p>"}]}